{
  "annotations": { "list": [] },
  "editable": true,
  "graphTooltip": 0,
  "schemaVersion": 39,
  "title": "Healthcare API",
  "uid": "healthcare-api",
  "tags": ["healthcare"],
  "time": { "from": "now-1h", "to": "now" },
  "timezone": "browser",
  "refresh": "30s",
  "templating": { "list": [] },
  "panels": [
    {
      "type": "row",
      "title": "HTTP",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 }
    },
    {
      "type": "timeseries",
      "title": "요청률 (req/s) by status",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 1 },
      "fieldConfig": { "defaults": { "unit": "reqps" }, "overrides": [] },
      "targets": [
        {
          "expr": "sum by (status) (rate(http_server_requests_seconds_count[1m]))",
          "legendFormat": "{{status}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "지연 p95 / p99 (s)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 1 },
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le) (rate(http_server_requests_seconds_bucket[5m])))",
          "legendFormat": "p95",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.99, sum by (le) (rate(http_server_requests_seconds_bucket[5m])))",
          "legendFormat": "p99",
          "refId": "B"
        }
      ]
    },
    {
      "type": "stat",
      "title": "5xx 비율 (%)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 6, "w": 6, "x": 0, "y": 9 },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null },
            { "color": "red", "value": 5 }
          ] }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "100 * (sum(rate(http_server_requests_seconds_count{status=~\"5..\"}[5m])) or vector(0)) / clamp_min(sum(rate(http_server_requests_seconds_count[5m])), 1)",
          "refId": "A"
        }
      ]
    },
    {
      "type": "row",
      "title": "JVM",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 15 }
    },
    {
      "type": "timeseries",
      "title": "힙 사용량 (bytes)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "fieldConfig": { "defaults": { "unit": "bytes" }, "overrides": [] },
      "targets": [
        {
          "expr": "sum(jvm_memory_used_bytes{area=\"heap\"})",
          "legendFormat": "heap used",
          "refId": "A"
        },
        {
          "expr": "sum(jvm_memory_max_bytes{area=\"heap\"})",
          "legendFormat": "heap max",
          "refId": "B"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "GC pause (s/s)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] },
      "targets": [
        {
          "expr": "sum by (action) (rate(jvm_gc_pause_seconds_sum[1m]))",
          "legendFormat": "{{action}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "row",
      "title": "DB / Redis",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 24 }
    },
    {
      "type": "timeseries",
      "title": "HikariCP 커넥션",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 25 },
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "targets": [
        { "expr": "hikaricp_connections_active", "legendFormat": "active", "refId": "A" },
        { "expr": "hikaricp_connections_idle", "legendFormat": "idle", "refId": "B" },
        { "expr": "hikaricp_connections_max", "legendFormat": "max", "refId": "C" }
      ]
    },
    {
      "type": "row",
      "title": "비즈니스",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 33 }
    },
    {
      "type": "timeseries",
      "title": "인증 (회원가입 / 로그인 result별)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 34 },
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "targets": [
        { "expr": "sum(increase(healthcare_auth_register_total[5m]))", "legendFormat": "register", "refId": "A" },
        { "expr": "sum by (result) (increase(healthcare_auth_login_total[5m]))", "legendFormat": "login {{result}}", "refId": "B" }
      ]
    },
    {
      "type": "timeseries",
      "title": "식단 기록 생성 / AI 분석 지연",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 34 },
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "targets": [
        { "expr": "sum(increase(healthcare_diet_log_created_total[5m]))", "legendFormat": "diet logs (5m)", "refId": "A" },
        { "expr": "histogram_quantile(0.95, sum by (le) (rate(healthcare_diet_ai_analysis_seconds_bucket[5m])))", "legendFormat": "AI p95 (s)", "refId": "B" }
      ]
    }
  ]
}
