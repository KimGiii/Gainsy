# Backend environment variables — copy to .env and fill in values
# DO NOT commit .env (it's in .gitignore)

# ── JWT ────────────────────────────────────────────────────────────────────────
# Must be at least 32 characters. Use a cryptographically random string in prod.
JWT_SECRET=change-me-minimum-32-characters-long

# ── Database (local: docker compose up -d) ─────────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=healthcare_db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# ── Redis ──────────────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379

# ── S3 / LocalStack (local) ────────────────────────────────────────────────────
# Leave S3_ENDPOINT empty to use real AWS; set to http://localhost:4566 for LocalStack
S3_ENDPOINT=http://localhost:4566
S3_BUCKET=healthcare-photos-local
S3_REGION=ap-northeast-2
S3_PATH_STYLE_ACCESS=true
S3_UPLOAD_PREFIX=progress-photos
S3_MEAL_UPLOAD_PREFIX=meal-photos

# ── AI / OpenAI ────────────────────────────────────────────────────────────────
# Required only when AI meal photo analysis is used
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com
OPENAI_MEAL_MODEL=gpt-4.1-mini

# ── Public Food API (식품안전처) ────────────────────────────────────────────────
# Get a key at https://openapi.foodsafetykorea.go.kr/
PUBLIC_FOOD_API_KEY=
PUBLIC_FOOD_API_URL=https://openapi.foodsafetykorea.go.kr/api

# ── Monitoring (Grafana) ─────────────────────────────────────────────────────────
# docker compose up -d prometheus grafana → http://localhost:3000 (admin / 아래 값)
GRAFANA_ADMIN_PASSWORD=admin

# ── Production-only ────────────────────────────────────────────────────────────
# These are injected via GitHub Secrets in CI and not needed locally
# DB_URL=jdbc:postgresql://host:5432/db
# DB_USERNAME=
# DB_PASSWORD=
# FCM_CREDENTIALS_PATH=/etc/healthcare/fcm-credentials.json
# S3_PUBLIC_ENDPOINT=https://api.gainsy.site/s3
