# infra/terraform/aws/terraform.tfvars.example
# 이 파일을 terraform.tfvars로 복사한 뒤 실제 값을 채워서 사용
# terraform.tfvars는 .gitignore에 포함되어야 함

aws_region   = "ap-northeast-2"
environment  = "dev"          # dev 또는 prod
project_name = "healthcare"

# 네트워크
allowed_ssh_cidrs = ["YOUR_IP/32"]   # 본인 IP: curl ifconfig.me

# EC2
ec2_instance_type = "t3.small"
ec2_key_name      = "healthcare-dev-key"   # AWS 콘솔에서 미리 생성한 키 페어 이름

# RDS
rds_instance_class = "db.t3.micro"
db_name            = "healthcare"
db_username        = "healthcare"
db_password        = "CHANGE_ME_MIN_16_CHARS!!"   # 반드시 변경

# ElastiCache
redis_node_type = "cache.t3.micro"

# S3
bucket_name          = "healthcare-photos-dev-YOUR_ACCOUNT_ID"
cors_allowed_origins = ["*"]

# DNS (Route 53)
# 도메인 등록처에서 Route 53 NS 4개로 변경해야 동작한다.
root_domain = "example.com"
